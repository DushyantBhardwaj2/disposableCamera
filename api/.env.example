# Required runtime configuration (Render)
PORT=8080
S3_BUCKET=your-bucket-name
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
UPLOAD_SIGNING_SECRET=change-me-in-production
ADMIN_PASSWORD=change-me-in-production
# Use Render persistent disk path in production.
SQLITE_PATH=/var/data/wedding.db
MAX_UPLOAD_BYTES=8388608

# Optional (for S3-compatible stores like MinIO/Cloudflare R2-compatible API)
# S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com
# S3_FORCE_PATH_STYLE=0
